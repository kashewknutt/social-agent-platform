.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
node_modules/
*.log
.DS_Store

# Other plugin clones (fetched by setup — not vendored in git)
plugins/bot-linkedin/
plugins/bot-x/
!plugins/.gitkeep

# Instagram plugin is vendored here when sibling-repo push is unavailable.
# Keep secrets / browser profiles / runtime artifacts ignored.
plugins/bot-instagram/.env
plugins/bot-instagram/.venv/
plugins/bot-instagram/**/__pycache__/
plugins/bot-instagram/**/*.egg-info/
plugins/bot-instagram/data/browser-profile/
plugins/bot-instagram/data/chrome-profile/
plugins/bot-instagram/data/usage_log.json
plugins/bot-instagram/data/interactions.db
plugins/bot-instagram/data/ig_agent.db
plugins/bot-instagram/data/video_analyses.db
plugins/bot-instagram/data/engage_circuit.json
plugins/bot-instagram/data/hashtag_search_history.jsonl
plugins/bot-instagram/data/scripted_fallback_log.json
plugins/bot-instagram/data/runs/
plugins/bot-instagram/data/raw/*.json
!plugins/bot-instagram/data/raw/sample_scraped.json
plugins/bot-instagram/data/filtered/*.json
!plugins/bot-instagram/data/filtered/.gitkeep
plugins/bot-instagram/data/media/
plugins/bot-instagram/reports/*.md
!plugins/bot-instagram/reports/.gitkeep

# agent-sdk is vendored with the engage flag when sibling-repo push is unavailable.
agent-sdk/.venv/
agent-sdk/**/__pycache__/
agent-sdk/**/*.egg-info/
agent-sdk/.pytest_cache/

**/data/browser-profile/
**/data/chrome-profile/
**/data/usage_log.json
**/data/interactions.db
**/data/*.db
!**/data/samples/**
**/data/*.jsonl
**/data/engage_circuit.json
**/data/scripted_fallback_log.json
orchestrator/data/
**/data/runs/
**/data/raw/*.json
!**/data/raw/sample_scraped.json
**/data/filtered/*.json
**/data/media/
**/reports/*.md
session.json
