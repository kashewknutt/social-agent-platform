# Kimi / Moonshot AI API key — get from https://platform.kimi.ai
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Optional overrides
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_FILTER_MODEL=kimi-k2.6
KIMI_SYNTH_MODEL=kimi-k3
KIMI_BROWSER_MODEL=kimi-k2.6
# Hard timeout (seconds) on each Kimi/Moonshot HTTP call so a slow/stuck API
# call can't hang the filter/scoring step forever — falls back to offline scoring.
KIMI_REQUEST_TIMEOUT_S=45
# Score posts in chunks of this size so partial progress can be shown live
# instead of waiting on one giant batch call.
FILTER_BATCH_SIZE=6

# Optional system Chrome path (ingest uses bundled Chromium for login persistence)
# Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# Persistent browser profile for Instagram login (avoid "chrome" in the path name)
BROWSER_USER_DATA_DIR=./data/browser-profile

# Safety / rate limits
MAX_POSTS_PER_SESSION=20
MAX_SCROLL_SESSIONS_PER_DAY=10
SESSION_MAX_MINUTES=45

# Engagement daily caps (auto like/follow during browse; HITL: comment/DM/post)
MAX_LIKES_PER_DAY=80
MAX_FOLLOWS_PER_DAY=40
MAX_COMMENTS_PER_DAY=12
MAX_DMS_PER_DAY=8
MAX_POSTS_PER_DAY=2
ENGAGE_AFTER_RESEARCH=true

# Soft pause after IG challenge (minutes). Escalates on repeats up to max.
ENGAGE_CIRCUIT_MINUTES=5
ENGAGE_CIRCUIT_MAX_MINUTES=20
# Alternate Chromium profiles to rotate into after Resume+rotate
ENGAGE_PROFILE_SLOTS=2

# Multimodal analysis (Step 5)
MULTIMODAL_TOP_N=3
ENABLE_MULTIMODAL=false

# Filter: posts scoring at or above this are kept (0-100). Default 35 — was 60.
RELEVANCE_THRESHOLD=35

# Scripted scrape + engagement (fast path, no LLM per action)
USE_SCRIPTED_SCRAPER=true
USE_SCRIPTED_ENGAGEMENT=true
SCRIPTED_ACTION_TIMEOUT_S=6.0

# During ingest: popup on each reel to approve/edit comment before posting (pauses scroll)
INGEST_LIVE_COMMENT_PROMPT=true
INGEST_COMMENT_TIMEOUT_S=180

# Don't reuse the same hashtag search within this many days (history in data/hashtag_search_history.jsonl)
HASHTAG_COOLDOWN_DAYS=2
